# audit.tcyr — tests for src/audit.cyr

include "src/lib.cyr"

fn t_audit_action_str() {
    assert_eq(streq(audit_action_str(AUDIT_COMMAND), "COMMAND"), 1, "COMMAND");
    assert_eq(streq(audit_action_str(AUDIT_AUTH_FAILURE), "AUTH_FAILURE"), 1, "AUTH_FAILURE");
    assert_eq(streq(audit_action_str(AUDIT_TIMESTAMP_INVALIDATED),
    "TIMESTAMP_INVALIDATED"), 1, "TIMESTAMP_INVALIDATED");
    assert_eq(streq(audit_action_str(999), "UNKNOWN"), 1, "unknown action");
}

fn t_default_audit_path() {
    assert_eq(streq(default_audit_log_path(), "/var/log/agnos/sudo.log"), 1, "default path");
}

fn _contains(hay, needle) {
    var hl = str_len(hay);
    var nl = strlen(needle);
    if (nl > hl) { return 0; }
    var hd = str_data(hay);
    var i = 0;
    while (i + nl <= hl) {
        if (memeq(hd + i, needle, nl) == 1) { return 1; }
        i = i + 1;
    }
    return 0;
}

fn t_build_file_line_has_fields() {
    var line = _build_file_line("alice", "root", "/usr/bin/ls");
    assert_eq(_contains(line, "alice"), 1, "caller present");
    assert_eq(_contains(line, "root"), 1, "target present");
    assert_eq(_contains(line, "/usr/bin/ls"), 1, "command present");
    assert_eq(_contains(line, "USER=root"), 1, "USER= field");
    assert_eq(_contains(line, "COMMAND=/usr/bin/ls"), 1, "COMMAND= field");
}

fn t_build_stderr_line_allowed() {
    var line = _build_stderr_line(AUDIT_COMMAND, "alice", "root", "/usr/bin/ls", 1, "authorized");
    assert_eq(_contains(line, "COMMAND"), 1, "action COMMAND");
    assert_eq(_contains(line, "STATUS=ALLOWED"), 1, "STATUS=ALLOWED");
    assert_eq(_contains(line, "REASON=authorized"), 1, "REASON=authorized");
}

fn t_build_stderr_line_denied() {
    var line = _build_stderr_line(AUDIT_AUTH_FAILURE, "eve", "root", "/bin/sh", 0, "bad password");
    assert_eq(_contains(line, "AUTH_FAILURE"), 1, "action AUTH_FAILURE");
    assert_eq(_contains(line, "STATUS=DENIED"), 1, "STATUS=DENIED");
}

fn main() {
    alloc_init();

    test_group("audit_action_str");
    t_audit_action_str();

    test_group("paths");
    t_default_audit_path();

    test_group("line builders");
    t_build_file_line_has_fields();
    t_build_stderr_line_allowed();
    t_build_stderr_line_denied();

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
