# env.tcyr — tests for src/env.cyr
# Mirrors rust-old/src/env.rs #[test] cases where feasible. Some Rust tests
# mutate the process environment to verify pass-through; we test that
# logic directly via is_unsafe_env / is_safe_env / _mk_env_pair.

include "src/lib.cyr"

# ── Unsafe predicate ────────────────────

fn t_unsafe_contains_ld_preload() {
    assert_eq(is_unsafe_env("LD_PRELOAD"), 1, "LD_PRELOAD");
    assert_eq(is_unsafe_env("LD_LIBRARY_PATH"), 1, "LD_LIBRARY_PATH");
}

fn t_unsafe_contains_bash_env() {
    assert_eq(is_unsafe_env("BASH_ENV"), 1, "BASH_ENV");
    assert_eq(is_unsafe_env("IFS"), 1, "IFS");
}

fn t_unsafe_contains_ld_extras() {
    assert_eq(is_unsafe_env("LD_HWCAP_MASK"), 1, "LD_HWCAP_MASK");
    assert_eq(is_unsafe_env("LD_TRACE_LOADED_OBJECTS"), 1, "LD_TRACE_LOADED_OBJECTS");
    assert_eq(is_unsafe_env("LD_WARN"), 1, "LD_WARN");
    assert_eq(is_unsafe_env("LD_VERBOSE"), 1, "LD_VERBOSE");
    assert_eq(is_unsafe_env("LD_TRACE_PRELINKING"), 1, "LD_TRACE_PRELINKING");
}

fn t_unsafe_contains_interpreters() {
    assert_eq(is_unsafe_env("PYTHONPATH"), 1, "PYTHONPATH");
    assert_eq(is_unsafe_env("PYTHONSTARTUP"), 1, "PYTHONSTARTUP");
    assert_eq(is_unsafe_env("PERL5LIB"), 1, "PERL5LIB");
    assert_eq(is_unsafe_env("PERL_MM_OPT"), 1, "PERL_MM_OPT");
    assert_eq(is_unsafe_env("RUBYLIB"), 1, "RUBYLIB");
    assert_eq(is_unsafe_env("GEM_HOME"), 1, "GEM_HOME");
    assert_eq(is_unsafe_env("GEM_PATH"), 1, "GEM_PATH");
    assert_eq(is_unsafe_env("BUNDLE_GEMFILE"), 1, "BUNDLE_GEMFILE");
    assert_eq(is_unsafe_env("NODE_PATH"), 1, "NODE_PATH");
    assert_eq(is_unsafe_env("NODE_OPTIONS"), 1, "NODE_OPTIONS");
    assert_eq(is_unsafe_env("CLASSPATH"), 1, "CLASSPATH");
    assert_eq(is_unsafe_env("JAVA_TOOL_OPTIONS"), 1, "JAVA_TOOL_OPTIONS");
    assert_eq(is_unsafe_env("LUA_PATH"), 1, "LUA_PATH");
    assert_eq(is_unsafe_env("LUA_CPATH"), 1, "LUA_CPATH");
    assert_eq(is_unsafe_env("PHPRC"), 1, "PHPRC");
}

fn t_unsafe_contains_shell_extras() {
    assert_eq(is_unsafe_env("INPUTRC"), 1, "INPUTRC");
}

fn t_unsafe_ld_prefix_catchall() {
    assert_eq(is_unsafe_env("LD_FUTURE_EXPLOIT"), 1, "unknown LD_ is unsafe");
    assert_eq(is_unsafe_env("LD_"), 1, "LD_ prefix alone");
}

fn t_unsafe_bash_func_prefix() {
    assert_eq(is_unsafe_env("BASH_FUNC_exploit%%"), 1, "BASH_FUNC_ prefix");
    assert_eq(is_unsafe_env("BASH_FUNC_anything"), 1, "BASH_FUNC_ catch-all");
}

fn t_safe_vars() {
    assert_eq(is_safe_env("TERM"), 1, "TERM");
    assert_eq(is_safe_env("LANG"), 1, "LANG");
    assert_eq(is_safe_env("TZ"), 1, "TZ");
    assert_eq(is_safe_env("DISPLAY"), 1, "DISPLAY");
}

fn t_safe_negatives() {
    assert_eq(is_safe_env("LD_PRELOAD"), 0, "LD_PRELOAD not safe");
    assert_eq(is_safe_env("RANDOM_VAR"), 0, "RANDOM_VAR not safe");
}

# ── _mk_env_pair / _env_key ────────────────────

fn t_mk_env_pair_basic() {
    var p = _mk_env_pair("USER", "root");
    assert_eq(streq(p, "USER=root"), 1, "USER=root");
}

fn t_mk_env_pair_empty_val() {
    var p = _mk_env_pair("KEY", "");
    assert_eq(streq(p, "KEY="), 1, "KEY=");
}

fn t_env_key_basic() {
    var k = _env_key("FOO=bar");
    assert_eq(streq(k, "FOO"), 1, "extract FOO");
}

fn t_env_key_no_equals() {
    var k = _env_key("NOEQUALS");
    assert_eq(k, 0, "no '=' returns 0");
}

# ── sanitize_environment ────────────────────
# Verifies invariants rather than exact pass-through (which depends on
# the test runner's inherited environment).

fn _find_key(env_vec, key) {
    var n = vec_len(env_vec);
    var i = 0;
    while (i < n) {
        var entry = vec_get(env_vec, i);
        var k = _env_key(entry);
        if (k != 0) {
            if (streq(k, key) == 1) { return entry; }
        }
        i = i + 1;
    }
    return 0;
}

fn t_sanitize_sets_user() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var u = _find_key(env, "USER");
    assert_neq(u, 0, "USER present");
    assert_eq(streq(u, "USER=root"), 1, "USER=root");
}

fn t_sanitize_sets_logname() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var l = _find_key(env, "LOGNAME");
    assert_neq(l, 0, "LOGNAME present");
    assert_eq(streq(l, "LOGNAME=root"), 1, "LOGNAME=root");
}

fn t_sanitize_sets_home_shell() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var h = _find_key(env, "HOME");
    var s = _find_key(env, "SHELL");
    assert_eq(streq(h, "HOME=/root"), 1, "HOME=/root");
    assert_eq(streq(s, "SHELL=/bin/bash"), 1, "SHELL=/bin/bash");
}

fn t_sanitize_sets_path() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var p = _find_key(env, "PATH");
    assert_neq(p, 0, "PATH present");
    var expected = "PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin";
    assert_eq(streq(p, expected), 1, "PATH hardcoded");
}

fn t_sanitize_sets_sudo_user() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var su = _find_key(env, "SUDO_USER");
    assert_eq(streq(su, "SUDO_USER=alice"), 1, "SUDO_USER=alice");
}

fn t_sanitize_sets_sudo_uid_gid() {
    var env = sanitize_environment(0, "alice", 1000, 1001, "root", "/root", "/bin/bash");
    var ui = _find_key(env, "SUDO_UID");
    var gi = _find_key(env, "SUDO_GID");
    assert_eq(streq(ui, "SUDO_UID=1000"), 1, "SUDO_UID");
    assert_eq(streq(gi, "SUDO_GID=1001"), 1, "SUDO_GID");
}

fn t_sanitize_excludes_unsafe() {
    var env = sanitize_environment(0, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    var n = vec_len(env);
    var i = 0;
    while (i < n) {
        var entry = vec_get(env, i);
        var k = _env_key(entry);
        if (k != 0) {
            assert_eq(is_unsafe_env(k), 0, "no unsafe vars in output");
        }
        i = i + 1;
    }
}

fn t_sanitize_env_keep_cannot_override_unsafe() {
    # Even if env_keep lists an unsafe var, it must not appear in the output.
    var keep = vec_new();
    vec_push(keep, "PYTHONPATH");
    vec_push(keep, "IFS");
    vec_push(keep, "LD_PRELOAD");
    var env = sanitize_environment(keep, "alice", 1000, 1000, "root", "/root", "/bin/bash");
    assert_eq(_find_key(env, "PYTHONPATH"), 0, "PYTHONPATH blocked");
    assert_eq(_find_key(env, "IFS"), 0, "IFS blocked");
    assert_eq(_find_key(env, "LD_PRELOAD"), 0, "LD_PRELOAD blocked");
}

fn main() {
    alloc_init();

    test_group("unsafe predicate");
    t_unsafe_contains_ld_preload();
    t_unsafe_contains_bash_env();
    t_unsafe_contains_ld_extras();
    t_unsafe_contains_interpreters();
    t_unsafe_contains_shell_extras();
    t_unsafe_ld_prefix_catchall();
    t_unsafe_bash_func_prefix();
    t_safe_vars();
    t_safe_negatives();

    test_group("_mk_env_pair / _env_key");
    t_mk_env_pair_basic();
    t_mk_env_pair_empty_val();
    t_env_key_basic();
    t_env_key_no_equals();

    test_group("sanitize_environment");
    t_sanitize_sets_user();
    t_sanitize_sets_logname();
    t_sanitize_sets_home_shell();
    t_sanitize_sets_path();
    t_sanitize_sets_sudo_user();
    t_sanitize_sets_sudo_uid_gid();
    t_sanitize_excludes_unsafe();
    t_sanitize_env_keep_cannot_override_unsafe();

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
