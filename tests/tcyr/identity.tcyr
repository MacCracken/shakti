# identity.tcyr — tests for src/identity.cyr
#
# Tests run against the live system's /etc/passwd and /etc/group.
# Anchored on POSIX-mandated entries (uid/gid 0 = "root") so they
# pass on any reasonable Linux host.

include "src/lib.cyr"

# ── identity_lookup_uid ────────────────────

fn t_lookup_uid_root() {
    var name_ptr = alloc(8);
    store64(name_ptr, 0);
    var gid_ptr = alloc(8);
    store64(gid_ptr, 0);
    var r = identity_lookup_uid(0, name_ptr, gid_ptr);
    assert_eq(r, 1, "uid 0 found");
    assert_eq(streq(load64(name_ptr), "root"), 1, "uid 0 name is root");
    assert_eq(load64(gid_ptr), 0, "uid 0 primary gid is 0");
}

fn t_lookup_uid_missing() {
    var name_ptr = alloc(8);
    store64(name_ptr, 0);
    var gid_ptr = alloc(8);
    store64(gid_ptr, 0);
    # uid 999999 is unlikely to exist on a real host
    var r = identity_lookup_uid(999999, name_ptr, gid_ptr);
    assert_eq(r, 0, "missing uid returns 0");
}

# ── identity_lookup_user ────────────────────

fn t_lookup_user_root() {
    var uid_ptr = alloc(8);
    store64(uid_ptr, 12345);  # poison
    var gid_ptr = alloc(8);
    store64(gid_ptr, 12345);
    var r = identity_lookup_user("root", uid_ptr, gid_ptr);
    assert_eq(r, 1, "user 'root' found");
    assert_eq(load64(uid_ptr), 0, "root uid is 0");
    assert_eq(load64(gid_ptr), 0, "root primary gid is 0");
}

fn t_lookup_user_empty() {
    var uid_ptr = alloc(8);
    var gid_ptr = alloc(8);
    var r = identity_lookup_user("", uid_ptr, gid_ptr);
    assert_eq(r, 0, "empty name returns 0");
}

fn t_lookup_user_missing() {
    var uid_ptr = alloc(8);
    var gid_ptr = alloc(8);
    var r = identity_lookup_user("__definitely_not_a_user__", uid_ptr, gid_ptr);
    assert_eq(r, 0, "missing user returns 0");
}

fn t_lookup_user_substring_safety() {
    # If a real user "root" exists, a name that is a strict prefix
    # ("roo") must NOT match the "root" line. This guards against
    # the colon-anchored prefix-match logic regressing.
    var uid_ptr = alloc(8);
    var gid_ptr = alloc(8);
    var r = identity_lookup_user("roo", uid_ptr, gid_ptr);
    assert_eq(r, 0, "'roo' must not match 'root:' line");
}

# ── identity_lookup_groups ────────────────────

fn t_lookup_groups_root_well_formed() {
    # `identity_lookup_groups` returns vec<cstr> of every group the
    # user is in: their primary group from /etc/passwd plus every
    # /etc/group entry whose member list names them. Anchor only on
    # structural guarantees: non-null vec, every entry a non-empty
    # cstr, no duplicates. Specific contents vary by distro (stock
    # Ubuntu's group "root" has empty member list; Arch typically
    # lists root explicitly), so don't pin those.
    var groups = identity_lookup_groups("root");
    assert_eq(groups != 0, 1, "lookup returns a non-null vec");
    var n = vec_len(groups);
    var i = 0;
    while (i < n) {
        var name = vec_get(groups, i);
        assert_eq(name != 0, 1, "group entry is non-null");
        assert_eq(strlen(name) > 0, 1, "group entry is non-empty");
        # Linear dedup check (n is tiny — typical 0..3).
        var j = i + 1;
        while (j < n) {
            assert_eq(streq(name, vec_get(groups, j)) == 0, 1, "no duplicates");
            j = j + 1;
        }
        i = i + 1;
    }
}

fn t_lookup_groups_root_includes_primary() {
    # New in 0.2.4: identity_lookup_groups now matches getgrouplist(3)
    # semantics — it includes the user's primary group, even if the
    # /etc/group member-list is empty (the common case for "root" on
    # Ubuntu/Debian). Root's primary gid is universally 0 = group
    # "root", so this is a portable assertion.
    var groups = identity_lookup_groups("root");
    var n = vec_len(groups);
    var found_root = 0;
    var i = 0;
    while (i < n) {
        if (streq(vec_get(groups, i), "root") == 1) { found_root = 1; }
        i = i + 1;
    }
    assert_eq(found_root, 1, "root user includes group 'root' (primary)");
}

fn t_lookup_groups_missing_user() {
    # Unknown user: no /etc/passwd entry, no /etc/group member-list
    # match. Result is empty.
    var groups = identity_lookup_groups("__definitely_not_a_user__");
    assert_eq(vec_len(groups), 0, "missing user yields empty group vec");
}

fn t_lookup_groups_empty_user() {
    var groups = identity_lookup_groups("");
    assert_eq(vec_len(groups), 0, "empty username yields empty group vec");
}

# ── identity_lookup_gids ────────────────────

fn t_lookup_gids_root_primary_first() {
    var buf = alloc(1024);
    var n = identity_lookup_gids("root", 0, buf, 256);
    # Always at least primary
    assert_eq(n >= 1, 1, "at least primary gid");
    assert_eq(load32(buf), 0, "primary gid (0) is first entry");
}

fn t_lookup_gids_dedup_primary() {
    # root is in group root (gid 0). Pass primary_gid = 0 — gid 0
    # must NOT be appended a second time.
    var buf = alloc(1024);
    var n = identity_lookup_gids("root", 0, buf, 256);
    var zero_count = 0;
    var i = 0;
    while (i < n) {
        if (load32(buf + i * 4) == 0) { zero_count = zero_count + 1; }
        i = i + 1;
    }
    assert_eq(zero_count, 1, "primary gid is not duplicated by /etc/group entry");
}

fn t_lookup_gids_zero_max() {
    var buf = alloc(8);
    var n = identity_lookup_gids("root", 0, buf, 0);
    assert_eq(n, 0, "max_count==0 writes nothing");
}

fn t_lookup_gids_missing_user_just_primary() {
    var buf = alloc(1024);
    var n = identity_lookup_gids("__definitely_not_a_user__", 99, buf, 256);
    assert_eq(n, 1, "missing user yields primary only");
    assert_eq(load32(buf), 99, "primary gid stored correctly");
}

# ── NSS group backend toggle + fail-safe fallback (ADR-010) ────────
# The trusted fdlopen helper (/usr/lib/cyrius/dlopen-helper) is not
# present in the test environment, so identity_nss_status() reports
# unavailable (0) once requested, and every lookup falls back to the
# /etc/group reader. These tests assert the toggle semantics and that
# the fallback is transparent — group results are identical to the
# files backend. (The live NSS path can only be exercised on a host
# with the helper installed + an NSS source; that is an integration
# concern, not a unit one.)

fn t_nss_default_not_requested() {
    # Fresh process default: backend not requested → status -1.
    assert_eq(identity_nss_status(), 0 - 1, "nss backend default: not requested (-1)");
}

fn t_nss_enabled_falls_back_when_helper_absent() {
    identity_set_nss_groups(1);
    # No system helper in the test env → init_trusted fails closed →
    # status 0 (requested but unavailable, files fallback in effect).
    assert_eq(identity_nss_status(), 0, "nss requested but helper absent → 0 (fallback)");

    # Fallback is transparent: root still resolves its groups via files.
    var groups = identity_lookup_groups("root");
    assert(vec_len(groups) >= 1, "root groups still resolved via files fallback");

    # And gid collection still yields at least the primary.
    var buf = alloc(1024);
    var n = identity_lookup_gids("root", 0, buf, 256);
    assert(n >= 1, "gid fallback yields >=1 (primary)");
    assert_eq(load32(buf), 0, "primary gid 0 in slot 0 under fallback");
}

fn t_nss_toggle_back_off() {
    identity_set_nss_groups(0);
    assert_eq(identity_nss_status(), 0 - 1, "toggling off restores not-requested (-1)");
}

# F-1 (0.7.0 audit): the getgrouplist widen path must clamp the count to
# the destination capacity BEFORE writing — never trust a foreign-libc
# return value to bound the write (CVE-2003-0689 getgrouplist-overflow
# class). _identity_widen_gids is the pure, isolated guard.
fn t_widen_gids_clamps_to_max() {
    # Source holds 8 u32 gids; destination sized for only 4.
    var src = alloc(8 * 4);
    var i = 0;
    while (i < 8) { store32(src + i * 4, 100 + i); i = i + 1; }
    # Poison dst slot 4 (i64 stride) to detect any write past the cap.
    var dst = alloc(8 * 8);
    store64(dst + 4 * 8, 0 - 999);

    # Hostile/contract-violating count of 8 against max 4 → clamp to 4.
    var n = _identity_widen_gids(src, 8, 4, dst);
    assert_eq(n, 4, "count clamped to max (8 → 4)");
    assert_eq(load64(dst + 0 * 8), 100, "slot 0 widened");
    assert_eq(load64(dst + 3 * 8), 103, "slot 3 widened (last in-bounds)");
    assert_eq(load64(dst + 4 * 8), 0 - 999, "slot 4 untouched — no overwrite past max");

    # Normal in-bounds count copies exactly that many.
    var dst2 = alloc(8 * 8);
    var n2 = _identity_widen_gids(src, 3, 4, dst2);
    assert_eq(n2, 3, "in-bounds count copied verbatim");
    assert_eq(load64(dst2 + 2 * 8), 102, "slot 2 widened");

    # Negative count (defensive) → zero writes.
    var n3 = _identity_widen_gids(src, 0 - 1, 4, dst2);
    assert_eq(n3, 0, "negative count clamps to 0");
}

# ── Overflow guard on numeric field parser (H-2 regression) ────────
# _identity_parse_uint is internal; test via a synthetic buffer that
# simulates an /etc/passwd line with a huge numeric uid field. The
# parser should reject the overflow rather than wrap.

fn _make_buf(s) {
    var n = strlen(s);
    var buf = alloc(n + 1);
    memcpy(buf, s, n);
    store8(buf + n, 0);
    return buf;
}

fn t_parse_uint_overflow_rejected() {
    # Buffer: "99999999999999999999" (20 digits — well past UINT_MAX).
    # Returns -1 on overflow rather than wrapping to a small value.
    var s = "99999999999999999999";
    var buf = _make_buf(s);
    var r = _identity_parse_uint(buf, 0, strlen(s));
    assert_eq(r, 0 - 1, "overflow past UINT_MAX rejected with -1");
}

fn t_parse_uint_at_uint_max_accepted() {
    # UINT_MAX = 4294967295 (10 digits) — exactly at the cap.
    var s = "4294967295";
    var buf = _make_buf(s);
    var r = _identity_parse_uint(buf, 0, strlen(s));
    assert_eq(r, 4294967295, "UINT_MAX exactly accepted");
}

fn t_parse_uint_just_over_uint_max_rejected() {
    # 4294967296 = UINT_MAX + 1.
    var s = "4294967296";
    var buf = _make_buf(s);
    var r = _identity_parse_uint(buf, 0, strlen(s));
    assert_eq(r, 0 - 1, "UINT_MAX + 1 rejected");
}

fn t_parse_uint_normal_values() {
    # Sanity: normal uids still parse.
    var s = "1000";
    var buf = _make_buf(s);
    assert_eq(_identity_parse_uint(buf, 0, strlen(s)), 1000, "1000 parses");
    s = "0";
    buf = _make_buf(s);
    assert_eq(_identity_parse_uint(buf, 0, strlen(s)), 0, "0 parses");
}

fn main() {
    alloc_init();

    test_group("identity lookups");
    t_lookup_uid_root();
    t_lookup_uid_missing();
    t_lookup_user_root();
    t_lookup_user_empty();
    t_lookup_user_missing();
    t_lookup_user_substring_safety();
    t_lookup_groups_root_well_formed();
    t_lookup_groups_root_includes_primary();
    t_lookup_groups_missing_user();
    t_lookup_groups_empty_user();
    t_lookup_gids_root_primary_first();
    t_lookup_gids_dedup_primary();
    t_lookup_gids_zero_max();
    t_lookup_gids_missing_user_just_primary();

    test_group("nss group backend toggle + fail-safe fallback (ADR-010)");
    t_nss_default_not_requested();
    t_nss_enabled_falls_back_when_helper_absent();
    t_nss_toggle_back_off();
    t_widen_gids_clamps_to_max();

    test_group("parse_uint overflow guard (H-2)");
    t_parse_uint_overflow_rejected();
    t_parse_uint_at_uint_max_accepted();
    t_parse_uint_just_over_uint_max_rejected();
    t_parse_uint_normal_values();

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
